<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Appointment Confirmed</title>
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        background: #f4f4f5;
        color: #1f2937;
        margin: 0;
        padding: 0;
      }
      .email-wrapper {
        background-color: #ffffff;
        max-width: 600px;
        margin: 0 auto;
      }
      .header {
        background-color: #18181b;
        text-align: center;
        padding: 30px 20px;
      }
      .header img {
        height: 50px;
        margin-bottom: 15px;
      }
      .header h1 {
        color: #10b981; /* Green checkmark text */
        font-size: 20px;
        margin: 0;
        font-weight: 600;
      }
      .content {
        padding: 40px 30px;
      }
      .greeting {
        font-size: 16px;
        margin-bottom: 20px;
      }
      .details-box {
        background-color: #f8fafc;
        border-left: 4px solid #10b981;
        border-radius: 6px;
        padding: 24px;
        margin: 30px 0;
      }
      .label {
        font-size: 12px;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 8px;
        font-weight: 600;
      }
      .value {
        font-size: 18px;
        font-weight: 700;
        color: #0f172a;
        margin: 0 0 5px 0;
      }
      .time-value {
        color: #ea580c; /* Orange */
        font-size: 16px;
        font-weight: 700;
        margin-top: 0;
      }
      .divider {
        height: 1px;
        background-color: #e2e8f0;
        margin: 20px 0;
      }
      .btn-container {
        text-align: center;
        margin: 30px 0;
      }
      .btn {
        display: inline-block;
        padding: 10px 20px;
        background-color: #f8fafc;
        color: #334155;
        text-decoration: none;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        font-weight: 500;
        font-size: 14px;
      }
      .contact-info {
        font-size: 15px;
        color: #334155;
      }
      .contact-info a {
        color: #ea580c;
        text-decoration: none;
        font-weight: 500;
      }
      .footer {
        background-color: #18181b;
        color: #ffffff;
        text-align: center;
        padding: 20px;
        font-size: 14px;
        font-weight: 500;
      }
    </style>
  </head>
  <body>
    <div class="email-wrapper">
      
      <div class="header">
        <img src="https://i.ibb.co.com/ZRkqH3kJ/logo.jpg" alt="Texas Precision Roofing" />
        <h1>✓ Appointment Confirmed</h1>
      </div>

      <div class="content">
        <div class="greeting">
          <p>Hi <%= firstName %>,</p>
          <p>Your appointment with <strong>Texas Precision Roofing & Contracting</strong> has been confirmed!</p>
        </div>

        <div class="details-box">
          <div class="label">Date & Time</div>
          <p class="value"><%= formattedDate %></p>
          <p class="time-value"><%= time %></p>
          
          <div class="divider"></div>
          
          <div class="label">Service</div>
          <p class="value" style="font-size: 16px;"><%= service %></p>
        </div>

        <div class="btn-container">
          <a href="#" class="btn">Reschedule or Cancel</a>
        </div>

        <div class="contact-info">
          <p>Questions? Call us at <a href="tel:2147087177">(214) 708-7177</a>.</p>
          <p>We look forward to seeing you!</p>
        </div>
      </div>

      <div class="footer">
        Texas Precision Roofing & Contracting
      </div>

    </div>
  </body>
</html>